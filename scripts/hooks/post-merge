#!/usr/bin/env sh
#
# post-merge hook — remind devs to check bd ready after pulling
#
if command -v bd >/dev/null 2>&1; then
  READY_COUNT=$(bd ready --json 2>/dev/null | jq 'length' 2>/dev/null || echo "0")
  if [ "$READY_COUNT" -gt 0 ]; then
    echo ""
    echo "===================================="
    echo "  bd: $READY_COUNT task(s) ready"
    echo "  Run 'bd ready' to see them"
    echo "===================================="
    echo ""
  fi
fi
